generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CurrencyCode {
  CAD
  USD
}

enum PortfolioAccountType {
  TFSA
  RRSP
  TAXABLE
  GENERAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  portfolio     Portfolio?
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Portfolio {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  baseCurrency       CurrencyCode
  rebalanceThreshold Decimal            @default(0.05) @db.Decimal(10, 4)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts           PortfolioAccount[]
  targets            PortfolioTarget[]

  @@index([userId])
}

model PortfolioAccount {
  id          String               @id @default(cuid())
  portfolioId String
  name        String
  accountType PortfolioAccountType
  currency    CurrencyCode
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  portfolio   Portfolio            @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  holdings    Holding[]

  @@unique([portfolioId, name])
  @@index([portfolioId])
}

model Etf {
  id         String         @id @default(cuid())
  ticker     String         @unique
  name       String
  currency   CurrencyCode
  assetClass String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  exposures  EtfExposure[]
  holdings   Holding[]
  prices     PriceHistory[]
  targets    PortfolioTarget[]
}

model EtfExposure {
  id           String   @id @default(cuid())
  etfId        String
  exposureType String
  exposureName String
  weight       Decimal  @db.Decimal(10, 4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  etf          Etf      @relation(fields: [etfId], references: [id], onDelete: Cascade)

  @@unique([etfId, exposureType, exposureName])
  @@index([etfId, exposureType])
}

model PriceHistory {
  id         String   @id @default(cuid())
  etfId      String
  priceDate  DateTime @db.Date
  closePrice Decimal  @db.Decimal(12, 4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  etf        Etf      @relation(fields: [etfId], references: [id], onDelete: Cascade)

  @@unique([etfId, priceDate])
  @@index([etfId, priceDate])
}

model Holding {
  id                 String           @id @default(cuid())
  accountId          String
  etfId              String
  units              Decimal          @db.Decimal(18, 6)
  averageCostPerUnit Decimal          @db.Decimal(12, 4)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  account            PortfolioAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  etf                Etf              @relation(fields: [etfId], references: [id], onDelete: Restrict)

  @@unique([accountId, etfId])
  @@index([accountId])
  @@index([etfId])
}

model PortfolioTarget {
  id           String    @id @default(cuid())
  portfolioId  String
  etfId        String
  targetWeight Decimal   @db.Decimal(10, 4)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  etf          Etf       @relation(fields: [etfId], references: [id], onDelete: Restrict)

  @@unique([portfolioId, etfId])
  @@index([portfolioId])
  @@index([etfId])
}
